# --- Kopyala: cp .env.example .env  (gerçek değerleri doldur) ---
#
# Maliyet / kota notları:
# - Google OAuth: Genelde ücretsiz; yanlışlıkla başka Google Cloud API açma.
# - X (Twitter) OAuth: developer.x.com planına göre kota / ücret.
# - Vercel (veya başka host): bant genişliği, Image Optimization, Edge — panelden izle.
# - Bu projede OpenAI/Stripe vb. ücretli API yok.

# NextAuth temel
AUTH_SECRET=
# Üret: openssl rand -base64 32
AUTH_URL=http://localhost:3000

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# X OAuth 2.0 (https://developer.x.com/en/portal/dashboard)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Yerelde Google/X kotasına hiç dokunma: true | 1
# AUTH_DISABLE_OAUTH=true

# Vercel vb. Image Optimization kullanma (origin’den doğrudan görsel; hosting kotası düşer)
# NEXT_IMAGE_UNOPTIMIZED=true

# ─── RapidAPI — X timeline (twitter-api45) ───────────────────────────────────
# https://rapidapi.com/alexanderxbx/api/twitter-api45 — Subscribe sonrası anahtar
# RAPIDAPI_KEY=
# İsteğe bağlı (varsayılan twitter-api45.p.rapidapi.com + /timeline.php)
# RAPIDAPI_TWITTER_HOST=twitter-api45.p.rapidapi.com
# RAPIDAPI_TWITTER_TIMELINE_PATH=/timeline.php
# Kategori başına en fazla kaç hesap timeline çağrısı (kota)
# RAPIDAPI_TWITTER_MAX_HANDLES=6
# Birleşik akışta üst sınır tweet sayısı
# RAPIDAPI_TWITTER_MAX_TWEETS=100
